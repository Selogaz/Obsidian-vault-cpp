      file.name: 530
      note.addition: 90
      note.status: 1
      note.priority: 1
  - type: table
    name: "👨 Group: By Creator"
    groupBy:
      property: creator
      direction: ASC
    order:
      - file.name
      - addition
      - status
      - priority
      - category
      - meta
      - problem
      - creator
      - production
      - start
      - end
      - url
    sort:
      - property: formula.kanban
        direction: ASC
      - property: status
        direction: DESC
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.status: 1
      note.priority: 1
  - type: table
    name: "🏬 Group: By Production"
    groupBy:
      property: production
      direction: ASC
    order:
      - file.name
      - addition
      - status
      - priority
      - category
      - meta
      - problem
      - creator
      - production
      - start
      - end
      - url
    sort:
      - property: formula.kanban
        direction: ASC
      - property: status
        direction: DESC
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.status: 1
      note.priority: 1
  - type: table
    name: ———
    filters:
      and:
        - "false"
    order:
      - file.name
  - type: table
    name: ❗ Overdue
    filters:
      and:
        - end
        - end < today()
        - and:
            - '!status.contains("⬛")'
            - '!status.contains("🟩")'
            - '!status.contains("📢")'
    groupBy:
      property: formula.priority
      direction: ASC
    order:
      - file.name
      - addition
      - status
      - priority
      - category
      - meta
      - problem
      - creator
      - production
      - start
      - end
      - url
    sort:
      - property: end
        direction: ASC
    columnSize:
      file.name: 530
      note.addition: 90
      note.status: 1
      note.priority: 1
      note.end: 120
  - type: table
    name: ———
    filters:
      and:
        - "false"
    order:
      - file.name
  - type: chart-bar
    name: "📈 Statistics: By Types"
    x: formula.type
    aggregate:file.name: Count
    show-labels: true
  - type: chart-bar
    name: "📈 Statistics: By Statuses"
    sort:
      - property: formula.kanban
        direction: ASC
    x: note.status
    aggregate:file.name: Count
    show-labels: true
  - type: chart-bar
    name: "📈 Statistics: By Category"
    x: note.category
    aggregate:file.name: Count
    show-labels: true
    sync-y-axes: false
    show-percentages: false
  - type: chart-bar
    name: "📈 Statistics: By End"
    filters:
      and:
        - end != null
    sort:
      - property: end
        direction: ASC
    x: formula.end_year
    aggregate:file.name: Count
    show-labels: true
    sync-y-axes: false
    show-percentages: false
  - type: table
    name: ———
    filters:
      and:
        - "false"
    order:
      - file.name
  - type: table
    name: ✅ Structure Validation
    filters:
      or:
        - formula.category_type_valid == "❌"
        - formula.meta_type_valid == "❌"
        - formula.problem_type_valid == "❌"
        - formula.creator_type_valid == "❌"
        - formula.production_type_valid == "❌"
    order:
      - file.name
      - formula.category_type_valid
      - category
      - formula.meta_type_valid
      - meta
      - formula.problem_type_valid
      - problem
      - formula.creator_type_valid
      - creator
      - formula.production_type_valid
      - production
    sort:
      - property: formula.category_type_valid
        direction: DESC
      - property: formula.meta_type_valid
        direction: DESC
      - property: formula.problem_type_valid
        direction: DESC
      - property: formula.creator_type_valid
        direction: DESC
      - property: formula.production_type_valid
        direction: DESC
      - property: file.name
        direction: ASC
    columnSize:
      file.name: 350
      formula.category_type_valid: 70
      formula.meta_type_valid: 1
      formula.problem_type_valid: 1
      formula.creator_type_valid: 1
      formula.production_type_valid: 1
      note.category: 180
      note.meta: 180
      note.problem: 180
      note.creator: 180
      note.production: 180
