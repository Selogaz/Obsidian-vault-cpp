      - addition
      - status
      - priority
      - category
      - meta
      - problem
      - creator
      - production
      - start
      - end
      - url
    sort:
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.status: 1
      note.priority: 1
  - type: table
    name: "🟦 Status: In Progress"
    filters:
      and:
        - status.contains("🟦")
    groupBy:
      property: formula.priority
      direction: ASC
    order:
      - file.name
      - addition
      - status
      - priority
      - category
      - meta
      - problem
      - creator
      - production
      - start
      - end
      - url
    sort:
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.status: 1
      note.priority: 1
  - type: table
    name: "🟩 Status: Done"
    filters:
      and:
        - status.contains("🟩")
    groupBy:
      property: formula.priority
      direction: ASC
    order:
      - file.name
      - addition
      - status
      - priority
      - category
      - meta
      - problem
      - creator
      - production
      - start
      - end
      - url
    sort:
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.status: 1
      note.priority: 1
  - type: table
    name: "📢 Status: Published"
    filters:
      and:
        - status.contains("📢")
    order:
      - file.name
      - addition
      - status
      - priority
      - category
      - meta
      - problem
      - creator
      - production
      - start
      - end
      - url
    sort:
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.status: 1
      note.priority: 1
  - type: table
    name: ———
    filters:
      and:
        - "false"
    order:
      - file.name
  - type: table
    name: "🗺️ Group: By Category"
    groupBy:
      property: category
      direction: ASC
    order:
      - file.name
      - addition
      - status
      - priority
      - category
      - meta
      - problem
      - creator
      - production
      - start
      - end
      - url
    sort:
      - property: formula.kanban
        direction: ASC
      - property: status
        direction: DESC
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.status: 1
      note.priority: 1
  - type: table
    name: "🔎 Group: By Meta"
    groupBy:
      property: meta
      direction: ASC
    order:
      - file.name
      - addition
      - status
      - priority
      - category
      - meta
      - problem
      - creator
      - production
      - start
      - end
      - url
    sort:
      - property: formula.kanban
        direction: ASC
      - property: status
        direction: DESC
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.status: 1
      note.priority: 1
  - type: table
    name: "⚡ Group: By Problem"
    groupBy:
      property: problem
      direction: ASC
    order:
      - file.name
      - addition
      - status
      - priority
      - category
      - meta
      - problem
      - creator
      - production
      - start
      - end
      - url
    sort:
      - property: formula.kanban
        direction: ASC
      - property: status
        direction: DESC
      - property: formula.created_relative
        direction: DESC
