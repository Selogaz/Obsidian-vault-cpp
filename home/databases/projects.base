      - meta
      - problem
      - creator
      - production
      - start
      - end
      - url
    sort:
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.status: 1
      note.priority: 1
  - type: table
    name: "❄ Status: Hold"
    filters:
      and:
        - status.contains("❄")
    groupBy:
      property: formula.priority
      direction: ASC
    order:
