filters:
  and:
    - or:
        - file.inFolder("base/contacts")
        - file.inFolder("base/creators")
        - file.inFolder("base/productions")
    - or:
        - '!this.file.hasTag("system/category")'
        - or:
            - file.hasTag("category/" + this.file.name.replace(" ", "_"))
            - category.contains(link(this.file.name))
formulas:
  backlinks: file.backlinks.length
  outlinks: file.links.length
  type: tags.toString().replace(/.*#(contact|creator|production)\/([^,]+).*/, "$2")
  created_relative: created.relative()
  updated_relative: updated.relative()
  category_status: if(!category.isEmpty(), "✅", "❌")
  category_type_valid: if(category.isEmpty(), "✅", if(list(category).filter(value.asFile().hasTag("system/category")).length == list(category).length, "✅", "❌"))
  meta_type_valid: if(meta.isEmpty(), "✅", if(list(meta).filter(value.asFile().hasTag("system/high/meta")).length == list(meta).length, "✅", "❌"))
  problem_type_valid: if(problem.isEmpty(), "✅", if(list(problem).filter(value.asFile().hasTag("system/high/problem")).length == list(problem).length, "✅", "❌"))
  production_type_valid: if(production.isEmpty(), "✅", if(list(production).filter(value.asFile().tags.filter(value.startsWith("#production/")).length > 0).length == list(production).length, "✅", "❌"))
properties:
  formula.type:
    displayName: 🗄️ type
  file.name:
    displayName: 🔤 title
  note.description:
    displayName: 🪪 description
  note.addition:
    displayName: ➕
  note.relevant:
    displayName: 📌
  note.category:
    displayName: 🗺️ category
  note.meta:
    displayName: 🔎 meta
  note.problem:
    displayName: ⚡ problem
  note.production:
    displayName: 🏬 production
  formula.backlinks:
    displayName: 🔽
  formula.outlinks:
    displayName: ⬆️
  formula.created_relative:
    displayName: 🆕 created
  formula.updated_relative:
    displayName: 🔄 updated
  note.tags:
    displayName: 🏷️ tags
  note.aliases:
    displayName: 🔖 aliases
  formula.category_status:
    displayName: structure
  formula.category_type_valid:
    displayName: type
  formula.meta_type_valid:
    displayName: 🏷️
  formula.problem_type_valid:
    displayName: 🏷️
  formula.production_type_valid:
    displayName: 🏷️
views:
  - type: table
    name: 👥 All People
    order:
      - relevant
      - formula.backlinks
      - formula.outlinks
      - file.name
      - addition
      - formula.type
      - description
      - category
      - meta
      - problem
      - production
      - formula.created_relative
      - formula.updated_relative
      - aliases
    sort:
      - property: relevant
        direction: DESC
    limit: 28
    columnSize:
      file.name: 530
      note.addition: 90
      note.relevant: 1
      formula.backlinks: 1
      formula.outlinks: 1
      formula.created_relative: 140
      formula.updated_relative: 140
  - type: table
    name: ———
    filters:
      and:
        - "false"
    order:
      - file.name
  - type: table
    name: "🗄️ Group: By Type"
    groupBy:
      property: formula.type
      direction: ASC
    order:
      - relevant
      - formula.backlinks
      - formula.outlinks
      - file.name
      - addition
      - formula.type
      - description
      - category
      - meta
      - problem
      - production
      - formula.created_relative
      - formula.updated_relative
    sort:
      - property: relevant
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.relevant: 1
      formula.backlinks: 1
      formula.outlinks: 1
      formula.created_relative: 140
      formula.updated_relative: 140
  - type: table
    name: ———
    filters:
      and:
        - "false"
    order:
      - file.name
  - type: table
    name: "👤 Type: Contacts"
    filters:
      and:
        - file.inFolder("base/contacts")
    order:
      - relevant
      - formula.backlinks
      - formula.outlinks
      - file.name
      - addition
      - formula.type
      - description
      - category
      - meta
      - problem
      - production
      - formula.created_relative
      - formula.updated_relative
    sort: []
    columnSize:
      file.name: 530
      note.addition: 90
      note.relevant: 1
      formula.backlinks: 1
      formula.outlinks: 1
      formula.created_relative: 140
      formula.updated_relative: 140
  - type: table
    name: "👨‍🎨 Type: Creators"
    filters:
      and:
        - file.inFolder("base/creators")
    order:
      - relevant
      - formula.backlinks
      - formula.outlinks
      - file.name
      - addition
      - formula.type
      - description
      - category
      - meta
      - problem
      - production
      - formula.created_relative
      - formula.updated_relative
    sort:
      - property: relevant
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.relevant: 1
      formula.backlinks: 1
      formula.outlinks: 1
      formula.created_relative: 140
      formula.updated_relative: 140
  - type: table
    name: "🏭 Type: Productions"
    filters:
      and:
        - file.inFolder("base/productions")
    order:
      - relevant
      - formula.backlinks
      - formula.outlinks
      - file.name
      - addition
      - formula.type
      - description
      - category
      - meta
      - problem
      - production
      - formula.created_relative
      - formula.updated_relative
    sort:
      - property: relevant
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.relevant: 1
      formula.backlinks: 1
      formula.outlinks: 1
      formula.created_relative: 140
      formula.updated_relative: 140
  - type: table
    name: ———
    filters:
      and:
        - "false"
    order:
      - file.name
  - type: table
    name: "🗺️ Group: By Category"
    filters:
      and:
        - "!category.isEmpty()"
    groupBy:
      property: category
      direction: ASC
    order:
      - relevant
      - formula.backlinks
      - formula.outlinks
      - file.name
      - addition
      - formula.type
      - description
      - category
      - meta
      - problem
      - production
      - formula.created_relative
      - formula.updated_relative
    sort:
      - property: relevant
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.relevant: 1
      formula.backlinks: 1
      formula.outlinks: 1
      formula.created_relative: 140
      formula.updated_relative: 140
  - type: table
    name: "🔎 Group: By Meta"
    filters:
