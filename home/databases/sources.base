filters:
  and:
    - file.inFolder("sources")
    - '!file.hasTag("mark/log")'
    - or:
        - '!this.file.hasTag("system/category")'
        - or:
            - file.hasTag("category/" + this.file.name.replace(" ", "_"))
            - category.contains(link(this.file.name))
formulas:
  type: file.tags.filter(value.startsWith("#source/"))[0].replace(/^.*\//, '')
  kanban: if(status.contains("⚛"), "① ⚛ Atom", if(status.contains("🟦"), "② 🟦 In Progress", if(status.contains("🟥"), "③ 🟥 ToDo", "④ Other")))
  scientificity: if(scientificity.contains("🅰️"), "① 🅰️ primary research", if(scientificity.contains("🅱️"), "② 🅱️ secondary research", if(scientificity.contains("👓"), "③ 👓 expert/industry", if(scientificity.contains("📢"), "④ 📢 popular science/journalism", if(scientificity.contains("💬"), "⑤ 💬 opinion/unverified", "⑥ Other")))))
  rating: if(rating.contains("🌕"), "① 🌕 masterpiece", if(rating.contains("🌔"), "② 🌔 great", if(rating.contains("🌓"), "③ 🌓 good", if(rating.contains("🌒"), "④ 🌒 mediocre", if(rating.contains("🌑"), "⑤ 🌑 poor", "⑥ Other")))))
  backlinks: file.backlinks.length
  outlinks: file.links.length
  created_relative: created.relative()
  updated_relative: updated.relative()
  category_status: if(!category.isEmpty(), "✅", "❌")
  category_type_valid: if(category.isEmpty(), "✅", if(list(category).filter(value.asFile().hasTag("system/category")).length == list(category).length, "✅", "❌"))
  meta_type_valid: if(meta.isEmpty(), "✅", if(list(meta).filter(value.asFile().hasTag("system/high/meta")).length == list(meta).length, "✅", "❌"))
  problem_type_valid: if(problem.isEmpty(), "✅", if(list(problem).filter(value.asFile().hasTag("system/high/problem")).length == list(problem).length, "✅", "❌"))
  creator_type_valid: if(creator.isEmpty(), "✅", if(list(creator).filter(value.asFile().tags.filter(value.startsWith("#creator/") || value.startsWith("#contact/")).length > 0).length == list(creator).length, "✅", "❌"))
  production_type_valid: if(production.isEmpty(), "✅", if(list(production).filter(value.asFile().tags.filter(value.startsWith("#production/")).length > 0).length == list(production).length, "✅", "❌"))
properties:
  formula.type:
    displayName: 🗄️ type
  note.zotero:
    displayName: 🇿
  note.addition:
    displayName: ➕
  note.status:
    displayName: 💯
  note.scientificity:
    displayName: 🅰️
  note.rating:
    displayName: 🌕️
  note.category:
    displayName: 🗺️ category
  note.meta:
    displayName: 🔎 meta
  note.problem:
    displayName: ⚡ problem
  note.creator:
    displayName: 👨 creator
  note.production:
    displayName: 🏬 production
  note.url:
    displayName: 🔗 url
  note.genre:
    displayName: 🎭 Genre
  note.published:
    displayName: 🗓️ Year
  file.name:
    displayName: 🔤 title
  formula.backlinks:
    displayName: 🔽
  formula.outlinks:
    displayName: ⬆️
  formula.created_relative:
    displayName: 🆕 created
  formula.updated_relative:
    displayName: 🔄 updated
  formula.category_status:
    displayName: structure
  formula.category_type_valid:
    displayName: type
  formula.meta_type_valid:
    displayName: 🏷️
  formula.problem_type_valid:
    displayName: 🏷️
  formula.creator_type_valid:
    displayName: 🏷️
  formula.production_type_valid:
    displayName: 🏷️
views:
  - type: table
    name: "📊 All: Short View"
    order:
      - file.name
      - addition
      - zotero
      - status
      - scientificity
      - rating
      - category
      - meta
      - problem
      - creator
      - production
      - url
    sort:
      - property: formula.kanban
        direction: ASC
      - property: formula.created_relative
        direction: DESC
    limit: 28
    columnSize:
      file.name: 530
      note.addition: 90
      note.zotero: 1
      note.status: 1
      note.scientificity: 1
      note.rating: 1
  - type: table
    name: "📊 All: Extended View"
    order:
      - formula.backlinks
      - formula.outlinks
      - formula.created_relative
      - formula.updated_relative
      - formula.type
      - file.name
      - addition
      - zotero
      - status
      - scientificity
      - rating
      - category
      - meta
      - problem
      - creator
      - production
      - url
    sort:
      - property: formula.kanban
        direction: ASC
      - property: formula.created_relative
        direction: DESC
    limit: 28
    columnSize:
      file.name: 530
      formula.backlinks: 1
      formula.outlinks: 1
      note.addition: 90
      note.zotero: 1
      note.status: 1
      note.scientificity: 1
      note.rating: 1
      formula.created_relative: 140
      formula.updated_relative: 140
  - type: table
    name: ———
    filters:
      and:
        - "false"
    order:
      - file.name
  - type: table
    name: "📋 Workflow: Kanban (v)"
    filters:
      or:
        - status.contains("⚛")
        - status.contains("🟦")
        - status.contains("🟥")
    groupBy:
      property: formula.kanban
      direction: ASC
    order:
      - file.name
      - addition
      - zotero
      - status
      - scientificity
      - rating
      - category
      - meta
      - problem
      - creator
      - production
      - url
    sort:
      - property: priority
        direction: ASC
    columnSize:
      file.name: 530
      note.addition: 90
      note.zotero: 1
      note.status: 1
      note.scientificity: 1
      note.rating: 1
  - type: board-view
    name: "📋 Workflow: Kanban (h)"
    order:
      - file.name
      - formula.type
      - scientificity
      - category
    groupProperty: note.status
    hideEmptyGroups: false
    hiddenGroups:
      - 💡
      - 🧠
      - 🖍
      - 🔎
      - 📦
      - 📋
      - ⚙️
      - 📢
      - Empty Group
      - ❄
      - ⬛
      - 🟩
    groupOrder:
      - 🟥
      - 🟦
      - ⚛
    colorCells: false
    colorHeaders: true
    colorCards: true
    hideEmptySubGroups: true
    iconProperty: note.status
  - type: table
    name: "🗄️ Workflow: Group By Type"
    filters:
      or:
        - status.contains("⚛")
        - status.contains("🟦")
        - status.contains("🟥")
    groupBy:
      property: formula.type
      direction: ASC
    order:
      - file.name
      - addition
      - zotero
      - status
      - scientificity
      - rating
      - category
      - meta
      - problem
      - creator
      - production
      - url
    sort:
      - property: formula.kanban
        direction: ASC
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.zotero: 1
      note.status: 1
      note.scientificity: 1
      note.rating: 1
  - type: table
    name: ———
    filters:
      and:
        - "false"
    order:
      - file.name
  - type: table
    name: "🟥 Status: To Do"
    filters:
      and:
        - status.contains("🟥")
    order:
      - file.name
      - addition
      - zotero
      - status
      - scientificity
      - rating
      - category
      - meta
      - problem
      - creator
      - production
      - url
    sort:
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.zotero: 1
      note.status: 1
      note.scientificity: 1
      note.rating: 1
  - type: table
    name: "🟦 Status: In Progress"
    filters:
      or:
        - status.contains("🟦")
        - status.contains("⚛")
    order:
      - file.name
      - addition
      - zotero
      - status
      - scientificity
      - rating
      - category
      - meta
      - problem
      - creator
      - production
      - url
    sort:
      - property: status
        direction: ASC
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.zotero: 1
      note.status: 1
      note.scientificity: 1
      note.rating: 1
  - type: table
    name: "🟩 Status: Done"
    filters:
      and:
        - status.contains("🟩")
    order:
      - file.name
      - addition
      - zotero
      - status
      - scientificity
      - rating
      - category
      - meta
      - problem
      - creator
      - production
      - url
    sort:
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.zotero: 1
      note.status: 1
      note.scientificity: 1
      note.rating: 1
  - type: table
    name: "⬛ Status: Drop"
    filters:
      and:
        - status.contains("⬛")
    order:
      - file.name
      - addition
      - zotero
      - status
      - scientificity
      - rating
      - category
      - meta
      - problem
      - creator
      - production
      - url
    sort:
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.zotero: 1
      note.status: 1
      note.scientificity: 1
      note.rating: 1
  - type: table
    name: ———
    filters:
      and:
        - "false"
    order:
      - file.name
  - type: table
    name: "🅰️ Group: By Scientificity"
    groupBy:
      property: formula.scientificity
      direction: ASC
    order:
      - file.name
      - addition
      - zotero
      - status
      - scientificity
      - rating
      - category
      - meta
      - problem
      - creator
      - production
      - url
    sort:
      - property: formula.kanban
        direction: ASC
      - property: status
        direction: DESC
      - property: formula.rating
        direction: ASC
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.zotero: 1
      note.status: 1
      note.scientificity: 1
      note.rating: 1
  - type: table
    name: "🌕 Group: By Rating"
    groupBy:
      property: formula.rating
      direction: ASC
    order:
      - file.name
      - addition
      - zotero
      - status
      - scientificity
      - rating
      - category
      - meta
      - problem
      - creator
      - production
      - url
    sort:
      - property: formula.kanban
        direction: ASC
      - property: status
        direction: DESC
      - property: formula.scientificity
        direction: ASC
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.zotero: 1
      note.status: 1
      note.scientificity: 1
      note.rating: 1
  - type: table
    name: "🗺️ Group: By Category"
    groupBy:
      property: category
