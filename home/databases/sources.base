      - creator
      - production
      - url
    sort:
      - property: formula.kanban
        direction: ASC
      - property: status
        direction: DESC
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.zotero: 1
      note.status: 1
      note.scientificity: 1
      note.rating: 1
  - type: table
    name: "🔎 Group: By Meta"
    groupBy:
      property: meta
      direction: ASC
    order:
      - file.name
      - addition
      - zotero
      - status
      - scientificity
      - rating
      - category
      - meta
      - problem
      - creator
      - production
      - url
    sort:
      - property: formula.kanban
        direction: ASC
      - property: status
        direction: DESC
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
      note.zotero: 1
      note.status: 1
      note.scientificity: 1
      note.rating: 1
  - type: table
    name: "⚡ Group: By Problem"
    groupBy:
      property: problem
      direction: ASC
    order:
      - file.name
      - addition
      - zotero
      - status
      - scientificity
      - rating
      - category
      - meta
      - problem
      - creator
      - production
      - url
    sort:
      - property: formula.kanban
        direction: ASC
      - property: status
        direction: DESC
      - property: formula.created_relative
        direction: DESC
    columnSize:
      file.name: 530
      note.addition: 90
