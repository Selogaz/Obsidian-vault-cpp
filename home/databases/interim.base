      - property: created
        direction: DESC
  - type: table
    name: 🤝 Negotiations
    filters:
      and:
        - file.inFolder("base/additions/negotiations")
    order:
      - file.name
      - status
      - formula.context
      - description
      - summary
    sort:
      - property: formula.kanban
        direction: ASC
      - property: created
        direction: DESC
  - type: table
    name: 💪 Practice
    filters:
      and:
        - file.inFolder("base/additions/practice")
    order:
      - file.name
      - status
      - formula.context
      - description
      - summary
    sort:
      - property: formula.kanban
        direction: ASC
      - property: created
        direction: DESC
  - type: table
    name: 🚨 Reports
    filters:
      and:
        - file.inFolder("base/additions/reports")
    order:
      - file.name
      - status
      - formula.context
      - description
      - summary
    sort:
